<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.RowConstraints?>
<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <GridPane HBox.hgrow="ALWAYS">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150"/>
            <ColumnConstraints hgrow="NEVER" minWidth="10" prefWidth="130"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints vgrow="ALWAYS" />
        </rowConstraints>

        <ScrollPane id="scrollPane" fx:id="contactInfoScrollPane" vbarPolicy="NEVER" hbarPolicy="AS_NEEDED"
                    GridPane.columnIndex="0" fitToWidth="true" GridPane.vgrow="ALWAYS">
            <VBox alignment="CENTER_LEFT">
                <padding>
                    <Insets top="5" right="5" bottom="15" left="15"/>
                </padding>
                <HBox spacing="0.5" alignment="CENTER_LEFT">
                    <Label fx:id="id" styleClass="cell_big_label">
                        <minWidth>
                            <!-- Ensures that the label text is never truncated -->
                            <Region fx:constant="USE_PREF_SIZE"/>
                        </minWidth>
                    </Label>
                    <Label fx:id="name" text="\$first" styleClass="cell_big_label">
                        <minWidth>
                            <Region fx:constant="USE_PREF_SIZE"/>
                        </minWidth>
                    </Label>
                </HBox>
                <HBox fx:id="tags" spacing="5"/>
                <VBox fx:id="fieldsContainer"/>
            </VBox>
        </ScrollPane>

        <ScrollPane fx:id="tutInfosScrollPane" prefWidth="130" fitToHeight="true" maxHeight="120"
                    styleClass="tut-info-scroll" GridPane.columnIndex="1">
            <VBox>
                <padding>
                    <Insets top="5" right="5" bottom="5" left="5"/>
                </padding>
                <Label text="Classes:" styleClass="cell_big_label"/>
                <VBox fx:id="tutInfosContainer"/>
            </VBox>
        </ScrollPane>

    </GridPane>
</HBox>
