<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.FlowPane?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" spacing="10">
  <Label fx:id="name" styleClass="name-label" wrapText="true" />

  <HBox fx:id="fieldsContainer">
    <VBox fx:id="fieldNamesColumn" styleClass="field-names-column" minWidth="80" prefWidth="100" />

    <ScrollPane fx:id="fieldValuesScrollPane" styleClass="field-values-scroll-pane" HBox.hgrow="ALWAYS"
        hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" fitToHeight="true">
      <VBox fx:id="fieldValuesColumn" styleClass="field-values-column" />
    </ScrollPane>
  </HBox>

  <FlowPane fx:id="tags" />
</VBox>
